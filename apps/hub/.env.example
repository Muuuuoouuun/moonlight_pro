# Current Hub env contract.
# Planned connector secrets and rollout order are documented in docs/integration-inventory.md.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key
COM_MOON_DEFAULT_WORKSPACE_ID=your-workspace-uuid
COM_MOON_ENGINE_URL=http://localhost:3001
COM_MOON_HUB_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
COM_MOON_PROJECTS_ROOT=/Users/bigmac_moon/Desktop/Projects
# Shared secret sent from Hub to Engine write routes.
COM_MOON_SHARED_WEBHOOK_SECRET=your-shared-webhook-secret
# Optional server-to-server guard for Hub write routes. Browser writes still
# require same-origin Origin/Referer headers.
COM_MOON_HUB_WRITE_SECRET=your-hub-write-secret
# Required for Google OAuth state payloads. Falls back to
# COM_MOON_SHARED_WEBHOOK_SECRET when omitted.
COM_MOON_OAUTH_STATE_SECRET=your-oauth-state-secret
GITHUB_TOKEN=your-github-token
# Comma-separated owner/repo list. If omitted, the hub auto-discovers mapped repos from COM_MOON_PROJECTS_ROOT when possible.
GITHUB_REPOSITORIES=Muuuuoouuun/moonlight_pro,classinkr-main/classinkr-web,Muuuuoouuun/sales_branding_dash,Muuuuoouuun/ai-command-pot
# Optional owner/repo=project_uuid map for project_updates created by GitHub sync.
GITHUB_PROJECT_MAP=Muuuuoouuun/moonlight_pro=your-project-uuid
# OpenClaw sync. Hub proxies to Engine with COM_MOON_SHARED_WEBHOOK_SECRET.
OPENCLAW_PROJECT_ID=your-project-uuid
OPENCLAW_SYNC_TRANSPORT=auto
OPENCLAW_LOCAL_URL=http://localhost:4317/webhook/moonlight
OPENCLAW_REMOTE_URL=https://your-openclaw.example/webhook/moonlight
OPENCLAW_SYNC_SECRET=your-openclaw-sync-secret
OPENCLAW_TELEGRAM_CHAT_ID=your-telegram-chat-id
OPENCLAW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/openclaw/webhook
# Gemini / Google AI Studio key used by Engine-backed AI routes.
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_ID=primary
# Gmail OAuth shares the same Google client and stores the refresh token in Supabase integration_connections.
# Optional fallback sender address if the connected Gmail address is not yet persisted.
GMAIL_SENDER_EMAIL=boss@your-domain.com
# Optional override for GitHub Enterprise or proxies.
# GITHUB_API_BASE_URL=https://api.github.com
