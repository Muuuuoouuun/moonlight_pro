# Current Hub env contract.
# Planned connector secrets and rollout order are documented in docs/integration-inventory.md.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key
COM_MOON_DEFAULT_WORKSPACE_ID=your-workspace-uuid
COM_MOON_ENGINE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
GITHUB_TOKEN=your-github-token
# Comma-separated owner/repo list. If omitted, the hub falls back to the current git remote when possible.
GITHUB_REPOSITORIES=Muuuuoouuun/moonlight_pro
# Optional override for GitHub Enterprise or proxies.
# GITHUB_API_BASE_URL=https://api.github.com
