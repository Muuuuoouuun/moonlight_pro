# Hub local-only overrides
# Copy to `.env.local` and fill real values when needed.

NEXT_PUBLIC_APP_URL=http://localhost:3000
COM_MOON_ENGINE_URL=http://localhost:3001

# Supabase client config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase server config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional legacy alias for older server helpers
# SUPABASE_ANON_KEY=your-anon-key

COM_MOON_DEFAULT_WORKSPACE_ID=11111111-1111-1111-1111-111111111111

# Optional GitHub wiring for PMS / roadmap surfaces
# GITHUB_TOKEN=your-github-token
# GITHUB_REPOSITORIES=Muuuuoouuun/moonlight_pro
