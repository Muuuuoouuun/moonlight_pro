# ─── Supabase (클라이언트) ────────────────────────────────────────────────────
# Supabase 프로젝트 설정에서 복사: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase (서버사이드) ────────────────────────────────────────────────────
# hub-gateway logger 가 사용. 절대 클라이언트에 노출 금지.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 사용 방법 ─────────────────────────────────────────────────────────────────
# 1. 이 파일을 복사: cp .env.local.example .env.local
# 2. 위 값을 실제 Supabase 값으로 교체
# 3. .env.local 은 .gitignore 에 포함되어 있어 커밋되지 않음
