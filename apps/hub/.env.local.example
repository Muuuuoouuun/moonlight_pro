# Hub local-only overrides
# Copy to `.env.local` and fill real values when needed.

NEXT_PUBLIC_APP_URL=http://localhost:3000
COM_MOON_HUB_URL=http://localhost:3000
COM_MOON_ENGINE_URL=http://localhost:3001

# Supabase client config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase server config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional legacy alias for older server helpers
# SUPABASE_ANON_KEY=your-anon-key

COM_MOON_DEFAULT_WORKSPACE_ID=11111111-1111-1111-1111-111111111111
COM_MOON_SHARED_WEBHOOK_SECRET=your-shared-webhook-secret
COM_MOON_HUB_WRITE_SECRET=your-hub-write-secret
# Required for Google OAuth state payloads. Falls back to the shared webhook
# secret when omitted.
COM_MOON_OAUTH_STATE_SECRET=your-oauth-state-secret

# Optional GitHub wiring for PMS / roadmap surfaces
# GITHUB_TOKEN=your-github-token
# GITHUB_REPOSITORIES=Muuuuoouuun/moonlight_pro
# GITHUB_PROJECT_MAP=Muuuuoouuun/moonlight_pro=33333333-3333-3333-3333-333333333331

# Optional OpenClaw sync. Use local when OpenClaw runs on this machine;
# otherwise use Telegram or Slack relay.
# OPENCLAW_PROJECT_ID=33333333-3333-3333-3333-333333333333
# OPENCLAW_SYNC_TRANSPORT=auto
# OPENCLAW_LOCAL_URL=http://localhost:4317/webhook/moonlight
# OPENCLAW_REMOTE_URL=
# OPENCLAW_SYNC_SECRET=your-openclaw-sync-secret
# OPENCLAW_TELEGRAM_CHAT_ID=your-telegram-chat-id
# OPENCLAW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/openclaw/webhook

# Optional AI wiring proxied through Engine
# GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# AI_DEFAULT_PROVIDER=gemini
# AI_DEFAULT_MODEL=gemini-3-flash-preview
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
