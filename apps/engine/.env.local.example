# ─── Supabase (서버사이드) ────────────────────────────────────────────────────
# webhook_events 저장 + hub-gateway 로거가 사용
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── n8n 자동화 ───────────────────────────────────────────────────────────────
# Telegram 웹훅 수신 후 n8n 으로 포워딩. 없으면 포워딩 건너뜀.
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/telegram

# ─── 사용 방법 ─────────────────────────────────────────────────────────────────
# 1. 이 파일을 복사: cp .env.local.example .env.local
# 2. 위 값을 실제 값으로 교체
# 3. .env.local 은 .gitignore 에 포함되어 있어 커밋되지 않음
