# Current Engine env contract.
# Planned connector secrets and rollout order are documented in docs/integration-inventory.md.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key
COM_MOON_DEFAULT_WORKSPACE_ID=your-workspace-uuid
DEFAULT_WORKSPACE_ID=your-workspace-uuid
# Shared secret for Engine write routes. When set, project webhooks and email send
# require x-com-moon-shared-secret or Authorization: Bearer.
COM_MOON_SHARED_WEBHOOK_SECRET=your-shared-webhook-secret
# Keep false unless you are running unauthenticated local smoke tests.
COM_MOON_ALLOW_OPEN_WEBHOOKS=false
# Telegram webhook secret configured with setWebhook secret_token.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
# Optional Telegram fan-out after local command handling.
N8N_WEBHOOK_URL=https://your-n8n.example/webhook/telegram
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=ops@your-domain.com
EMAIL_FROM_NAME=Com_Moon Ops
EMAIL_REPLY_TO_ADDRESS=reply@your-domain.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Optional fallback when Gmail OAuth has not been connected yet in the hub.
GOOGLE_REFRESH_TOKEN_BOSS=your-google-refresh-token
GMAIL_SENDER_EMAIL=boss@your-domain.com
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORIES=Muuuuoouuun/moonlight_pro
GITHUB_PROJECT_MAP=Muuuuoouuun/moonlight_pro=your-project-uuid
GITHUB_API_BASE_URL=https://api.github.com
OPENCLAW_PROJECT_ID=your-project-uuid
# auto chooses local -> remote -> Telegram -> Slack, based on configured values.
OPENCLAW_SYNC_TRANSPORT=auto
# Local OpenClaw instance endpoint, for the OpenClaw that runs on this machine.
OPENCLAW_LOCAL_URL=http://localhost:4317/webhook/moonlight
# Optional remote OpenClaw endpoint, if one of the two OpenClaw surfaces is not local.
OPENCLAW_REMOTE_URL=https://your-openclaw.example/webhook/moonlight
# Optional shared secret sent to direct local/remote OpenClaw endpoints.
OPENCLAW_SYNC_SECRET=your-openclaw-sync-secret
# Optional Telegram relay if OpenClaw listens in a Telegram chat.
OPENCLAW_TELEGRAM_CHAT_ID=your-telegram-chat-id
# Optional Slack relay if OpenClaw listens in Slack.
OPENCLAW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/openclaw/webhook
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
