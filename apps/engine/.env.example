# Current Engine env contract.
# Planned connector secrets and rollout order are documented in docs/integration-inventory.md.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key
COM_MOON_DEFAULT_WORKSPACE_ID=your-workspace-uuid
DEFAULT_WORKSPACE_ID=your-workspace-uuid
# Optional shared secret for partner webhook routes such as /api/webhook/project/openclaw.
COM_MOON_SHARED_WEBHOOK_SECRET=your-shared-webhook-secret
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=ops@your-domain.com
EMAIL_FROM_NAME=Com_Moon Ops
EMAIL_REPLY_TO_ADDRESS=reply@your-domain.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Optional fallback when Gmail OAuth has not been connected yet in the hub.
GOOGLE_REFRESH_TOKEN_BOSS=your-google-refresh-token
GMAIL_SENDER_EMAIL=boss@your-domain.com
