# Current env contract for live Hub/Engine wiring.
# Planned connector secrets and rollout order are documented in docs/integration-inventory.md.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

COM_MOON_DEFAULT_WORKSPACE_ID=11111111-1111-1111-1111-111111111111
COM_MOON_ENGINE_URL=http://localhost:3001
COM_MOON_HUB_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
COM_MOON_SHARED_WEBHOOK_SECRET=your-shared-webhook-secret
COM_MOON_HUB_WRITE_SECRET=your-hub-write-secret
COM_MOON_OAUTH_STATE_SECRET=your-oauth-state-secret
# Keep false unless you are running unauthenticated local smoke tests.
COM_MOON_ALLOW_OPEN_WEBHOOKS=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
N8N_WEBHOOK_URL=https://your-n8n.example/webhook/telegram
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=ops@your-domain.com
EMAIL_FROM_NAME=Com_Moon Ops
EMAIL_REPLY_TO_ADDRESS=reply@your-domain.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN_BOSS=your-google-refresh-token
GMAIL_SENDER_EMAIL=boss@your-domain.com
